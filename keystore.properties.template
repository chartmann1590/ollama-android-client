# Keystore properties for release signing
# Copy this file to keystore.properties and fill in your actual values
# 
# To generate a keystore, run:
# keytool -genkey -v -keystore app/release.keystore -alias ollama-release -keyalg RSA -keysize 2048 -validity 10000
#
# Then update the values below:
storeFile=app/release.keystore
storePassword=your_store_password
keyAlias=ollama-release
keyPassword=your_key_password

