# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout.
*.kt text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.pro text eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.apk binary
*.aar binary
*.jar binary
*.class binary
*.dex binary
*.so binary
*.a binary

# Gradle wrapper
gradlew text eol=lf
gradlew.bat text eol=crlf

